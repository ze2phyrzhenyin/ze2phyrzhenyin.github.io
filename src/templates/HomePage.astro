---
import Base from '@/layouts/Base.astro';
import { SITE, getSiteName } from '@/lib/config';
import { useTranslations, localizePath, defaultLang } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t    = useTranslations(lang);
const siteName = getSiteName(lang);

const audiences: {
  num: string;
  q: Parameters<typeof t>[0];
  desc: Parameters<typeof t>[0];
  cta: Parameters<typeof t>[0];
  slug: string;
}[] = [
  { num: '01', q: 'home.aud.1.q', desc: 'home.aud.1.desc', cta: 'home.aud.1.cta', slug: 'for-faculty' },
  { num: '02', q: 'home.aud.2.q', desc: 'home.aud.2.desc', cta: 'home.aud.2.cta', slug: 'for-collaborators' },
  { num: '03', q: 'home.aud.3.q', desc: 'home.aud.3.desc', cta: 'home.aud.3.cta', slug: 'for-peers' },
  { num: '04', q: 'home.aud.4.q', desc: 'home.aud.4.desc', cta: 'home.aud.4.cta', slug: 'for-help' },
  { num: '05', q: 'home.aud.5.q', desc: 'home.aud.5.desc', cta: 'home.aud.5.cta', slug: 'for-curious' },
];
---
<Base>
  <!-- ── Hero ── -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 dot-grid opacity-60 dark:opacity-30 pointer-events-none" />
    <div class="absolute inset-0 pointer-events-none"
         style="background:radial-gradient(ellipse 80% 60% at 50% 0%,transparent 40%,rgb(var(--bg)) 100%);"/>
    <div class="absolute -top-32 left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full pointer-events-none opacity-30 dark:opacity-20"
         style="background:radial-gradient(ellipse,hsl(var(--accent-h) var(--accent-s) var(--accent-l)/.25) 0%,transparent 70%);"/>
    <div class="container-narrow relative pt-24 pb-20">
      <div class="animate-fade-up inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-medium mb-6"
           style="background:rgb(var(--surface));border:1px solid rgb(var(--border));color:rgb(var(--text-2));">
        <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse-slow"></span>
        {t('home.status')}
      </div>
      <div class="flex flex-col sm:flex-row items-start gap-7 animate-fade-up delay-100">
        <div class="shrink-0 relative">
          <div class="w-20 h-20 rounded-2xl overflow-hidden ring-2 ring-offset-2"
               style="ring-color:rgb(var(--border-2));ring-offset-color:rgb(var(--bg));">
            <div class="w-full h-full bg-gradient-to-br from-primary-600 to-primary-800 flex items-center justify-center">
              <img src={SITE.avatar} alt={siteName} class="w-full h-full object-cover"
                   onerror="this.parentElement.innerHTML='<span style=color:white;font-size:1.5rem;font-weight:700;font-family:monospace>λ</span>'"/>
            </div>
          </div>
          <span class="absolute -bottom-0.5 -right-0.5 w-4 h-4 rounded-full bg-green-500 ring-2"
                style="ring-color:rgb(var(--bg));"></span>
        </div>
        <div>
          <h1 class="text-3xl sm:text-4xl font-bold tracking-tight leading-tight mb-1"
              style="color:rgb(var(--text));">{siteName}</h1>
          <p class="font-mono text-xs mb-4" style="color:rgb(var(--muted));">{SITE.tagline}</p>
          <p class="text-sm leading-relaxed max-w-lg mb-6" style="color:rgb(var(--text-2));">
            {t('home.bio.1')}
            {' '}<span style="color:rgb(var(--text));font-weight:500;">{t('home.bio.logic')}</span>{', '}
            <span style="color:rgb(var(--text));font-weight:500;">{t('home.bio.tt')}</span>
            {' '}{t('home.bio.2')}
          </p>
          <div class="flex flex-wrap gap-2">
            <a href={localizePath('/about', lang)} class="btn-primary">{t('home.cta.about')}</a>
            <a href={localizePath('/blog', lang)} class="btn-secondary">{t('home.cta.blog')}</a>
            <a href={localizePath('/about', lang) + '#education'} class="btn-secondary">{t('home.cta.cv')}</a>
            {SITE.github && (
              <a href={SITE.github} target="_blank" rel="noopener" class="btn-secondary">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
                </svg>
                GitHub
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Audience section ── -->
  <section class="container-narrow pb-28 animate-fade-up delay-200">
    <!-- Section header -->
    <div class="flex items-center gap-3 mb-1">
      <span class="font-mono text-base select-none" style="color:var(--accent);">§</span>
      <p class="font-mono text-xs tracking-widest uppercase" style="color:rgb(var(--muted));">{t('home.for')}</p>
      <div class="flex-1 h-px" style="background:rgb(var(--border));"></div>
    </div>

    <!-- Accordion list -->
    <div class="aud-list" role="list">
      {audiences.map(({ num, q, desc, cta, slug }) => (
        <details class="aud-item" role="listitem">
          <summary class="aud-summary" tabindex="0">
            <span class="aud-num">{num}</span>
            <span class="aud-question">{t(q)}</span>
            <span class="aud-icon" aria-hidden="true">
              <svg class="icon-plus w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14M5 12h14"/>
              </svg>
              <svg class="icon-minus w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14"/>
              </svg>
            </span>
          </summary>
          <div class="aud-body">
            <p class="aud-desc">{t(desc)}</p>
            <a href={localizePath(`/essays/${slug}`, lang)} class="aud-cta">
              {t(cta)}
            </a>
          </div>
        </details>
      ))}
    </div>
  </section>
</Base>

<style>
  /* ── List ── */
  .aud-list {
    border-top: 1px solid rgb(var(--border));
  }

  /* ── Item ── */
  .aud-item {
    border-bottom: 1px solid rgb(var(--border));
    transition: background 0.15s;
  }
  .aud-item[open] {
    background: rgb(var(--surface));
    border-radius: 0;
  }

  /* ── Summary row ── */
  .aud-summary {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 0.25rem;
    cursor: pointer;
    list-style: none;
    user-select: none;
    transition: opacity 0.15s;
  }
  .aud-summary::-webkit-details-marker { display: none; }
  .aud-summary:hover { opacity: 0.85; }

  /* ── Number ── */
  .aud-num {
    font-family: var(--font-mono, monospace);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: rgb(var(--muted));
    width: 2rem;
    shrink: 0;
    transition: color 0.15s;
  }
  .aud-item[open] .aud-num,
  .aud-item:hover .aud-num {
    color: var(--accent-text);
  }

  /* ── Question label ── */
  .aud-question {
    flex: 1;
    font-size: 0.9375rem;
    font-weight: 500;
    color: rgb(var(--text));
    line-height: 1.4;
  }

  /* ── +/- icon ── */
  .aud-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    color: rgb(var(--muted));
    transition: color 0.15s, transform 0.2s;
  }
  .aud-item:hover .aud-icon { color: rgb(var(--text-2)); }
  .icon-minus { display: none; }
  .aud-item[open] .icon-plus  { display: none; }
  .aud-item[open] .icon-minus { display: block; }
  .aud-item[open] .aud-icon   { color: var(--accent-text); }

  /* ── Body (expanded content) ── */
  .aud-body {
    padding: 0 0.25rem 1.5rem 3rem;
    animation: aud-in 0.18s ease-out;
  }
  @keyframes aud-in {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Description text ── */
  .aud-desc {
    font-size: 0.875rem;
    line-height: 1.75;
    color: rgb(var(--text-2));
    max-width: 52ch;
    margin-bottom: 1rem;
  }

  /* ── CTA link ── */
  .aud-cta {
    display: inline-flex;
    align-items: center;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--accent-text);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
  }
  .aud-cta:hover {
    border-bottom-color: var(--accent-text);
  }
</style>
