---
import Base from '@/layouts/Base.astro';
import EssayCard from '@/components/EssayCard.astro';
import { getAllEssays } from '@/lib/utils';
import { useTranslations, defaultLang } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t    = useTranslations(lang);
const essays = await getAllEssays();
---
<Base title={t('essays.title')} description={t('essays.desc')}>
  <div class="container-mid py-16">
    <header class="mb-10 animate-fade-up">
      <h1 class="text-4xl font-bold tracking-tight mb-2"
          style="color:rgb(var(--text));letter-spacing:-0.025em;">{t('essays.title')}</h1>
      <p class="text-sm max-w-md" style="color:rgb(var(--text-2));">{t('essays.desc')}</p>
    </header>
    {essays.length === 0 ? (
      <div class="text-center py-20">
        <p class="font-mono text-sm" style="color:rgb(var(--muted));">{t('essays.empty')}</p>
      </div>
    ) : (
      <div class="animate-fade-up delay-100">
        {essays.map(essay => <EssayCard essay={essay} />)}
        <div class="h-px" style="background:rgb(var(--border));"></div>
      </div>
    )}
  </div>
</Base>
