---
import Base from '@/layouts/Base.astro';
import { getAllPublications } from '@/lib/utils';
import { SITE } from '@/lib/config';
import { useTranslations, defaultLang } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t    = useTranslations(lang);

const pubs = await getAllPublications();
const byYear = pubs.reduce((acc, p) => { (acc[p.data.year] ??= []).push(p); return acc; }, {} as Record<number, typeof pubs>);
const years  = Object.keys(byYear).map(Number).sort((a, b) => b - a);

const typeKey: Record<string, string> = {
  journal: 'pubs.journal', conference: 'pubs.conference',
  preprint: 'pubs.preprint', thesis: 'pubs.thesis',
};
const typeColor: Record<string, string> = {
  journal: 'background:hsl(220 70% 95%);color:hsl(220 70% 35%);border-color:hsl(220 70% 88%);',
  conference: 'background:hsl(150 50% 94%);color:hsl(150 60% 28%);border-color:hsl(150 50% 85%);',
  preprint: 'background:hsl(38 80% 93%);color:hsl(38 70% 28%);border-color:hsl(38 80% 84%);',
  thesis: 'background:hsl(270 60% 95%);color:hsl(270 60% 35%);border-color:hsl(270 60% 88%);',
};
---
<Base title={t('pubs.title')} description={t('pubs.desc')}>
  <div class="container-mid py-16">
    <header class="flex items-start justify-between gap-4 mb-10 animate-fade-up">
      <div>
        <h1 class="text-4xl font-bold tracking-tight mb-2"
            style="color:rgb(var(--text));letter-spacing:-0.025em;">{t('pubs.title')}</h1>
        <p class="text-sm" style="color:rgb(var(--text-2));">{t('pubs.desc')}</p>
      </div>
      {SITE.googleScholar && (
        <a href={SITE.googleScholar} target="_blank" rel="noopener" class="btn-secondary shrink-0">
          Google Scholar ↗
        </a>
      )}
    </header>

    {pubs.length === 0 ? (
      <div class="text-center py-20">
        <p class="font-mono text-sm" style="color:rgb(var(--muted));">{t('pubs.empty')}</p>
      </div>
    ) : (
      <div class="space-y-14 animate-fade-up delay-100">
        {years.map(year => (
          <section>
            <div class="flex items-center gap-4 mb-7">
              <span class="font-mono text-2xl font-bold tabular" style="color:rgb(var(--text));">{year}</span>
              <div class="flex-1 h-px" style="background:rgb(var(--border));"></div>
            </div>
            <div class="space-y-6">
              {byYear[year].map(pub => (
                <article class="group pl-5 pub-item">
                  <div class="flex flex-wrap items-center gap-2 mb-2.5">
                    <span class="text-xs font-medium px-2 py-0.5 rounded-md"
                          style={`${typeColor[pub.data.type]}border:1px solid;`}>
                      {t(typeKey[pub.data.type] as any)}
                    </span>
                    {pub.data.featured && (
                      <span class="text-xs font-medium px-2 py-0.5 rounded-md"
                            style="background:var(--accent-dim);color:var(--accent-text);border:1px solid;">
                        {t('pubs.featured')}
                      </span>
                    )}
                  </div>
                  <h3 class="font-semibold text-base leading-snug mb-1.5 transition-colors duration-150 pub-title"
                      style="color:rgb(var(--text));">{pub.data.title}</h3>
                  <p class="text-sm mb-0.5" style="color:rgb(var(--text-2));">
                    {pub.data.authors.map((a, i) => (
                      <span class:list={[a === SITE.author && 'font-semibold underline decoration-dotted']}>
                        {i > 0 && ', '}{a}
                      </span>
                    ))}
                  </p>
                  <p class="text-sm italic mb-3" style="color:rgb(var(--muted));">
                    {pub.data.venue}, {pub.data.year}
                  </p>
                  <details>
                    <summary class="cursor-pointer text-xs select-none pub-summary" style="color:rgb(var(--muted));">
                      {t('pubs.abstract')}
                    </summary>
                    <p class="text-sm leading-relaxed pl-3 mt-1"
                       style="color:rgb(var(--text-2));border-left:2px solid rgb(var(--border));">
                      {pub.data.abstract}
                    </p>
                  </details>
                  <div class="flex flex-wrap gap-4 mt-2">
                    {pub.data.arxiv && <a href={pub.data.arxiv} target="_blank" rel="noopener" class="text-xs font-medium" style="color:var(--accent-text);">arXiv ↗</a>}
                    {pub.data.pdf && <a href={pub.data.pdf} target="_blank" rel="noopener" class="text-xs font-medium" style="color:var(--accent-text);">PDF ↗</a>}
                    {pub.data.doi && <a href={`https://doi.org/${pub.data.doi}`} target="_blank" rel="noopener" class="text-xs font-medium" style="color:rgb(var(--muted));">DOI ↗</a>}
                  </div>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>
    )}
  </div>
</Base>

<style>
  .pub-item { border-left: 2px solid rgb(var(--border)); transition: border-color .15s; }
  .pub-item:hover { border-left-color: var(--accent); }
  .pub-item:hover .pub-title { color: var(--accent-text); }
  .pub-summary:hover { color: rgb(var(--text)); }
</style>
