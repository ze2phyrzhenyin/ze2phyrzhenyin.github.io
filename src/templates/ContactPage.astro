---
import Base from '@/layouts/Base.astro';
import { SITE } from '@/lib/config';
import { useTranslations, defaultLang } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t    = useTranslations(lang);
---
<Base title={t('contact.title')} description={t('contact.desc')}>
  <div class="container-mid py-16">
    <header class="mb-10 animate-fade-up">
      <h1 class="text-4xl font-bold tracking-tight mb-2"
          style="color:rgb(var(--text));letter-spacing:-0.025em;">{t('contact.title')}</h1>
      <p class="text-sm max-w-sm" style="color:rgb(var(--text-2));">{t('contact.desc')}</p>
    </header>
    <div class="space-y-3 max-w-sm animate-fade-up delay-100">
      <a href={`mailto:${SITE.email}`} class="card-accent flex items-center gap-4 group">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background:var(--accent-dim);">
          <svg class="w-5 h-5" style="color:var(--accent-text);" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium" style="color:rgb(var(--text));">Email</p>
          <p class="font-mono text-xs truncate" style="color:rgb(var(--muted));">{SITE.email}</p>
        </div>
        <svg class="w-4 h-4 shrink-0 transition-transform group-hover:translate-x-0.5" style="color:rgb(var(--border-2));" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
      {SITE.github && (
        <a href={SITE.github} target="_blank" rel="noopener" class="card-accent flex items-center gap-4 group">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background:rgb(var(--surface-2));">
            <svg class="w-5 h-5" style="color:rgb(var(--text));" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium" style="color:rgb(var(--text));">GitHub</p>
            <p class="font-mono text-xs truncate" style="color:rgb(var(--muted));">{SITE.github.replace('https://github.com/', '@')}</p>
          </div>
          <svg class="w-4 h-4 shrink-0 transition-transform group-hover:translate-x-0.5" style="color:rgb(var(--border-2));" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      )}
      <div class="card flex items-center gap-4">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background:rgb(var(--surface-2));">
          <svg class="w-5 h-5" style="color:rgb(var(--text-2));" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-medium" style="color:rgb(var(--text));">{SITE.institution}</p>
          <p class="text-xs" style="color:rgb(var(--muted));">{SITE.department}</p>
        </div>
      </div>
    </div>
    <p class="mt-10 text-xs max-w-sm leading-relaxed animate-fade-up delay-200" style="color:rgb(var(--muted));">
      {t('contact.note')}
    </p>
  </div>
</Base>
