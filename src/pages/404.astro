---
import Base from '@/layouts/Base.astro';
import { useTranslations, defaultLang } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t    = useTranslations(lang);
---
<Base title={t('404.title')}>
  <div class="container-narrow py-32 text-center relative">
    <div class="absolute inset-0 dot-grid opacity-40 dark:opacity-20 pointer-events-none"></div>
    <div class="relative">
      <p class="font-mono font-bold leading-none mb-4 select-none"
         style="font-size:clamp(5rem,20vw,9rem);color:rgb(var(--border));letter-spacing:-0.05em;">404</p>
      <h1 class="text-2xl font-bold mb-2" style="color:rgb(var(--text));">{t('404.title')}</h1>
      <p class="font-mono text-sm mb-8" style="color:rgb(var(--muted));">{t('404.msg')}</p>
      <a href="/" class="btn-primary">{t('404.back')}</a>
    </div>
  </div>
</Base>
