---
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '@/lib/utils';
import { useTranslations, localizePath, defaultLang } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';
export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({ params: { slug: project.slug }, props: { project } }));
}
const { project } = Astro.props;
const { title, description, status, tags, github, demo, paper, date, cover } = project.data;
const { Content } = await project.render();
const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);
const statusDot: Record<string, string> = { active: 'bg-green-400', completed: 'bg-blue-400', archived: 'bg-stone-400' };
---
<Base title={title} description={description}>
  <div class="container-mid py-16">
    <div class="mb-8 animate-fade-in">
      <a href={localizePath('/projects', lang)} class="inline-flex items-center gap-1.5 text-sm transition-colors" style="color:rgb(var(--muted));">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        {t('projects.title')}
      </a>
    </div>
    <header class="mb-10 animate-fade-up">
      <div class="flex flex-wrap items-center gap-2.5 mb-4">
        <span class="inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1 rounded-full" style="background:rgb(var(--surface-2));border:1px solid rgb(var(--border));color:rgb(var(--text-2));">
          <span class={`w-1.5 h-1.5 rounded-full ${statusDot[status]}`}></span>
          {t(`status.${status}` as any)}
        </span>
        <span class="font-mono text-xs tabular" style="color:rgb(var(--muted));">{formatDate(date, { year: 'numeric', month: 'long' })}</span>
      </div>
      <h1 class="text-4xl font-bold tracking-tight mb-3" style="color:rgb(var(--text));letter-spacing:-0.025em;">{title}</h1>
      <p class="text-lg leading-relaxed mb-5" style="color:rgb(var(--text-2));font-family:Lora,serif;">{description}</p>
      <div class="flex flex-wrap gap-1.5 mb-6">{tags.map(tag => <span class="tag">{tag}</span>)}</div>
      <div class="flex flex-wrap gap-2">
        {github && <a href={github} target="_blank" rel="noopener" class="btn-secondary"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>Source</a>}
        {demo && <a href={demo} target="_blank" rel="noopener" class="btn-primary">Demo</a>}
        {paper && <a href={paper} target="_blank" rel="noopener" class="btn-secondary">Paper</a>}
      </div>
    </header>
    {cover && <img src={cover} alt={`${title} screenshot`} class="w-full rounded-2xl mb-10 animate-fade-up" style="border:1px solid rgb(var(--border));"/>}
    <div class="h-px mb-10" style="background:linear-gradient(90deg,var(--accent) 0%,transparent 40%);"></div>
    <div class="prose dark:prose-invert max-w-none animate-fade-up delay-100"><Content /></div>
    <div class="mt-16 pt-8" style="border-top:1px solid rgb(var(--border));">
      <a href={localizePath('/projects', lang)} class="inline-flex items-center gap-1.5 text-sm transition-colors" style="color:rgb(var(--muted));">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        {t('projects.title')}
      </a>
    </div>
  </div>
</Base>
