---
import { formatDate, readingTime, categoryBadge } from '@/lib/utils';
import { localizePath, defaultLang } from '@/i18n/utils';
import type { Lang } from '@/i18n/ui';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  featured?: boolean;
}
const { post, featured = false } = Astro.props;
const { title, description, date, category, tags } = post.data;
const rt = readingTime(post.body ?? '');
const lang = (Astro.currentLocale ?? defaultLang) as Lang;
---
<article class={`card-accent group relative flex flex-col ${featured ? 'sm:col-span-2' : ''}`}>
  <!-- Category + meta row -->
  <div class="flex items-center gap-2 mb-3">
    <a href={localizePath(`/blog?cat=${category}`, lang)} class={categoryBadge(category)}
       onclick="event.stopPropagation()" style="position:relative;z-index:1;">
      {category}
    </a>
    <span class="text-xs tabular" style="color: rgb(var(--muted));">
      {formatDate(date, { month: 'short', day: 'numeric', year: 'numeric' })}
    </span>
    <span class="text-xs" style="color: rgb(var(--border-2));">·</span>
    <span class="text-xs" style="color: rgb(var(--muted));">{rt}</span>
  </div>

  <!-- Title -->
  <h2 class="font-semibold text-base leading-snug mb-2 transition-colors duration-150"
      style="color: rgb(var(--text));">
    <a href={localizePath(`/blog/${post.slug}`, lang)} class="after:absolute after:inset-0"
       style="color: inherit; text-decoration: none;">
      {title}
    </a>
  </h2>

  <!-- Description -->
  <p class="text-sm leading-relaxed line-clamp-2 mb-4 flex-1"
     style="color: rgb(var(--text-2));">
    {description}
  </p>

  <!-- Tags -->
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1 mt-auto">
      {tags.slice(0, 4).map(tag => (
        <span class="font-mono text-[10px]" style="color: rgb(var(--muted));">#{tag}</span>
      ))}
    </div>
  )}
</article>

<style>
  article { position: relative; }
  /* Hover title color via CSS var */
  article:hover h2 { color: var(--accent-text); }
</style>
